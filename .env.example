# Copy to .env and replace every CHANGE_ME value before starting.
VAULTWARDEN_DOMAIN=http://127.0.0.1:8080
VAULTWARDEN_PORT=127.0.0.1:8080

# Keep true only until the sole account has been created, then set false.
SIGNUPS_ALLOWED=true

# Optional. If enabled, use an Argon2 PHC string generated by:
# docker run --rm -it vaultwarden/server:1.35.2 /vaultwarden hash
# ADMIN_TOKEN=CHANGE_ME

